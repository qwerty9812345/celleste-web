# Discord Application (создать: https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_BOT_TOKEN=your_bot_token

# ID Discord сервера семьи (ПКМ по серверу → Копировать ID)
GUILD_ID=your_guild_id

# Название роли для доступа к закрытой части
VERIFIED_ROLE=Celleste

# Секрет для сессий (любая случайная строка)
SESSION_SECRET=your_random_secret_here

# URL сайта (локально: http://localhost:3000, продакшн: https://...)
BASE_URL=http://localhost:3000

# Ссылка-приглашение на Discord сервер (https://discord.gg/...)
DISCORD_INVITE=
